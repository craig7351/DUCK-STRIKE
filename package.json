{
  "name": "duck-strike",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "pages:dev": "wrangler pages dev dist",
    "db:local": "wrangler d1 execute duck-strike-db --file=./schema.sql --local",
    "db:remote": "wrangler d1 execute duck-strike-db --file=./schema.sql --remote",
    "deploy": "vite build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@babylonjs/core": "^7.54.0",
    "@babylonjs/loaders": "^7.54.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0",
    "wrangler": "^3.90.0"
  }
}
